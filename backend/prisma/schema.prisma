// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  moduleFormat    = "cjs"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

/// Vai trò người dùng trong hệ thống
enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

/// Trạng thái kiểm duyệt tài liệu học thuật
/// PRIVATE: Vừa upload, chỉ người dùng thấy
/// PENDING: Đang chờ Admin kiểm duyệt
/// APPROVED: Đã được duyệt, công khai cho mọi người
enum DocumentStatus {
  PRIVATE
  PENDING
  APPROVED
}

/// Trạng thái tiến trình upload file lên Cloud Storage
enum UploadProgressStatus {
  UPLOADING
  COMPLETED
  FAILED
}

/// Trạng thái xử lý tóm tắt tài liệu của AI
enum SummaryStatus {
  PROCESSING
  COMPLETED
  FAILED
}

enum VisibilityStatus {
  PRIVATE
  PENDING_REVIEW
  PUBLIC
}

enum DeletionStatus {
  ACTIVE
  SOFT_DELETED
  DELETING
  DELETE_FAILED
  REMOVED
}

enum ExtractionStatus {
  PENDING
  READY
  FAILED
}

enum AIStatus {
  NOT_REQUESTED
  PROCESSING
  READY
  FAILED
}

/// Quản lý thông tin tài khoản người dùng
model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  username     String?  @unique
  phoneNumber  String?  @map("phone_number")
  avatarUrl    String?  @map("avatar_url")
  role         UserRole @default(STUDENT)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Quan hệ
  passwordResetTokens PasswordResetToken[]
  documents           Document[]
  uploadStatuses      UploadStatus[]
  quizzes             Quiz[]
  quizAttempts        UserQuizAttempt[]
  documentViews       UserDocumentView[]
  followedDocuments   UserFollowedDocument[]

  @@map("users")
}

/// Quản lý Token reset mật khẩu (Quên mật khẩu)
model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String    @unique
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("password_reset_tokens")
}

/// Danh mục Môn học/Mã học phần
model Subject {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  code        String   @unique
  description String?  @db.Text
  isSystem    Boolean  @default(false) @map("is_system")
  createdBy   String?  @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  // Quan hệ
  documents Document[]

  @@map("subjects")
}

/// Tag quản lý nhãn dán cho Document
model Tag {
  id        Int      @id @default(autoincrement())
  name      String
  slug      String
  createdBy String?  @map("created_by") @db.Uuid
  isSystem  Boolean  @default(false) @map("is_system")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")

  documents DocumentTag[]

  @@unique([slug, createdBy])
  @@map("tags")
}

/// Bảng trung gian Document và Tag
model DocumentTag {
  documentId String   @map("document_id") @db.Uuid
  tagId      Int      @map("tag_id")
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag        Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([documentId, tagId])
  @@map("document_tags")
}

/// Thông tin siêu dữ liệu tài liệu học thuật
model Document {
  id            String         @id @default(uuid()) @db.Uuid
  title         String
  description   String?        @db.Text
  subjectId     Int            @map("subject_id")
  subject       Subject        @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  uploadedBy    String         @map("uploaded_by") @db.Uuid
  user          User           @relation(fields: [uploadedBy], references: [id], onDelete: Cascade)
  fileUrl       String         @map("file_url") @db.VarChar(512)
  previewUrl    String?        @map("preview_url") @db.VarChar(512)
  fileSize      BigInt         @map("file_size")
  fileType      String         @map("file_type")
  downloadCount Int            @default(0) @map("download_count")
  viewCount     Int            @default(0) @map("view_count")
  status        DocumentStatus @default(PRIVATE)
  fullText      String?        @map("full_text") @db.Text
  isAIGenerated Boolean        @default(false) @map("is_ai_generated")
  rating        Float          @default(0.0) @map("rating")
  deletedAt     DateTime?      @map("deleted_at")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  // Document Lifecycle
  visibilityStatus VisibilityStatus @default(PRIVATE) @map("visibility_status")
  deletionStatus   DeletionStatus   @default(ACTIVE) @map("deletion_status")
  extractionStatus ExtractionStatus @default(PENDING) @map("extraction_status")
  storagePath      String?          @map("storage_path") @db.VarChar(512)

  // AI Fields
  aiStatus              AIStatus  @default(NOT_REQUESTED) @map("ai_status")
  aiRunId               String?   @map("ai_run_id")
  aiProcessingStartedAt DateTime? @map("ai_processing_started_at")
  aiGeneratedAt         DateTime? @map("ai_generated_at")
  aiAttemptCount        Int       @default(0) @map("ai_attempt_count")
  aiFailureReason       String?   @map("ai_failure_reason") @db.Text

  // Quan hệ
  summary        DocumentSummary?
  uploadStatuses UploadStatus[]
  quizzes        Quiz[]
  documentViews  UserDocumentView[]
  tags           DocumentTag[]
  followers      UserFollowedDocument[]
  chunks         DocumentChunk[]

  @@index([subjectId, status])
  @@map("documents")
}

/// Tóm tắt nội dung tài liệu học thuật do AI thực hiện
model DocumentSummary {
  id           String        @id @default(uuid()) @db.Uuid
  documentId   String        @unique @map("document_id") @db.Uuid
  document     Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)
  summaryText  String        @map("summary_text") @db.Text
  keyPoints    String?       @map("key_points") @db.Text
  status       SummaryStatus @default(PROCESSING)
  errorMessage String?       @map("error_message") @db.Text
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  @@map("document_summaries")
}

/// Theo dõi tiến trình tải file lên Cloud Storage
model UploadStatus {
  id           String               @id @default(uuid()) @db.Uuid
  documentId   String?              @map("document_id") @db.Uuid
  document     Document?            @relation(fields: [documentId], references: [id], onDelete: SetNull)
  userId       String               @map("user_id") @db.Uuid
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName     String               @map("file_name")
  fileSize     BigInt               @map("file_size")
  status       UploadProgressStatus @default(UPLOADING)
  progress     Int                  @default(0)
  errorMessage String?              @map("error_message") @db.Text
  createdAt    DateTime             @default(now()) @map("created_at")
  updatedAt    DateTime             @updatedAt @map("updated_at")

  @@map("upload_status")
}

/// Bộ câu hỏi trắc nghiệm AI sinh ra từ tài liệu
model Quiz {
  id         String   @id @default(uuid()) @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdBy  String?  @map("created_by") @db.Uuid
  user       User?    @relation(fields: [createdBy], references: [id], onDelete: SetNull)
  title      String
  createdAt  DateTime @default(now()) @map("created_at")

  // Quan hệ
  questions QuizQuestion[]
  attempts  UserQuizAttempt[]

  @@index([documentId])
  @@map("quizzes")
}

/// Chi tiết câu hỏi trong bộ Quiz trắc nghiệm
model QuizQuestion {
  id           String   @id @default(uuid()) @db.Uuid
  quizId       String   @map("quiz_id") @db.Uuid
  quiz         Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionText String   @map("question_text") @db.Text
  createdAt    DateTime @default(now()) @map("created_at")

  // Quan hệ
  options QuizOption[]

  @@index([quizId])
  @@map("quiz_questions")
}

/// Các đáp án lựa chọn trắc nghiệm của câu hỏi
model QuizOption {
  id         String       @id @default(uuid()) @db.Uuid
  questionId String       @map("question_id") @db.Uuid
  question   QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  optionText String       @map("option_text") @db.Text
  isCorrect  Boolean      @default(false) @map("is_correct")
  createdAt  DateTime     @default(now()) @map("created_at")

  @@index([questionId])
  @@map("quiz_options")
}

/// Nhật ký/Lịch sử làm bài làm trắc nghiệm của sinh viên
model UserQuizAttempt {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId      String   @map("quiz_id") @db.Uuid
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  score       Int
  completedAt DateTime @default(now()) @map("completed_at")

  @@index([userId, completedAt(sort: Desc)])
  @@map("user_quiz_attempts")
}

/// Nhật ký/Lịch sử xem tài liệu của người dùng
model UserDocumentView {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  viewedAt   DateTime @default(now()) @map("viewed_at")

  // Quan hệ
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId])
  @@index([userId, viewedAt(sort: Desc)])
  @@map("user_document_views")
}

/// Lưu/Theo dõi tài liệu của người dùng
model UserFollowedDocument {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  followedAt DateTime @default(now()) @map("followed_at")

  // Quan hệ
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([userId, documentId])
  @@map("user_followed_documents")
}

/// Chia nhỏ nội dung tài liệu để xử lý AI (RAG)
model DocumentChunk {
  id         String   @id @default(uuid()) @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  chunkIndex Int      @map("chunk_index")
  content    String   @db.Text
  charStart  Int      @map("char_start")
  charEnd    Int      @map("char_end")
  createdAt  DateTime @default(now()) @map("created_at")

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([documentId])
  @@map("document_chunks")
}
